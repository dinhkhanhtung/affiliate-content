\par {\listtext\pard\plain\f2\fs28\insrsid22763 \hich\af2\dbch\af0\loch\f2 2.\tab}}\pard \qj \fi-840\li1200\ri0\widctlpar\jclisttab\tx1200\aspalpha\aspnum\faauto\ls14\adjustright\rin0\lin1200\itap0\pararsid22763 {\f2\fs28\insrsid22763 
Increased physical activity
\par }\pard \qj \li360\ri0\widctlpar\aspalpha\aspnum\faauto\adjustright\rin0\lin360\itap0\pararsid2162834 {\f2\fs28\insrsid2162834 
